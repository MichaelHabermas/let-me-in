# Copy to `.env` for local Vite. Never commit `.env`.
# Admin credentials — both vars must be set together or the app uses dev-default (see README).
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=admin
# Optional: log embedding wall times in the gate pipeline (dev).
# VITE_LOG_EMBEDDING_TIMINGS=true
# E2E only — never set on production. Playwright enables this in playwright.config.ts.
# VITE_E2E_STUB_ENROLL=true
