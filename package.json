{
  "name": "let-me-in",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "seed:users": "vitest run --config vitest.seed.config.ts",
    "sync:netlify": "node scripts/sync-netlify-redirects.mjs",
    "verify:netlify": "node scripts/sync-netlify-redirects.mjs --check",
    "sweep": "pnpm run typecheck && pnpm run lint && pnpm run format && pnpm test",
    "construct": "pnpm run sweep && pnpm run build"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "onnxruntime-web": "^1.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
